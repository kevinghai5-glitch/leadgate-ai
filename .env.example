# Database
DATABASE_URL="postgresql://user:password@localhost:5432/leadgate?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional — enables "Continue with Google" on /login and /signup)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OpenAI
OPENAI_API_KEY="sk-your-openai-api-key"

# Stripe
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"
NEXT_PUBLIC_STRIPE_KEY="pk_test_your-stripe-publishable-key"
NEXT_PUBLIC_STRIPE_PRICE_ID="price_your-stripe-price-id"

# Slack
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/your/webhook/url"

# SMTP (for password reset emails)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="LeadGate AI <your-email@gmail.com>"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── ReclaimedHQ / agency provisioning ───────────────────────────────
# Public signup is closed. To create a tenant, POST /api/auth/signup with the
# header  x-admin-signup-key: <ADMIN_SIGNUP_KEY>. Accounts created this way are
# marked plan="agency" and bypass all subscription gates. If unset, signup is
# fully closed (no account can be created via the API).
ADMIN_SIGNUP_KEY=""

# Optional: encrypt tenant GoHighLevel Private Integration Tokens at rest with
# AES-256-GCM. Must be 32 bytes as 64 hex chars or base64. If unset, tokens are
# stored as plaintext (matches other columns, but a security downgrade for a
# long-lived credential — set this in production).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# GoHighLevel / LeadConnector: there is NO global GHL env var. Each tenant's
# Location ID, Private Integration Token, Pipeline ID, Stage IDs, and booking URL
# are configured per-user in the dashboard (Business Profile → GoHighLevel) and
# stored on the User row.

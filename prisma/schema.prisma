generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String   @id @default(cuid())
  email                    String   @unique
  password                 String?
  name                     String?
  emailVerified            DateTime?
  image                    String?
  stripeCustomerId         String?  @unique
  stripeSubscriptionId     String?  @unique
  stripeSubscriptionStatus String?  @default("inactive")
  plan                     String?  @default("free")
  calendarLink             String?
  slackWebhookUrl          String?
  // ─── GoHighLevel / LeadConnector per-tenant config (ReclaimedHQ retainer) ───
  // All optional: when unset, LeadGate behaves exactly as before (no GHL push).
  // ghlPrivateToken is a Sub-Account Private Integration Token; stored server-side
  // only, encrypted at rest when ENCRYPTION_KEY is set (see src/lib/crypto.ts).
  ghlLocationId            String?
  ghlPrivateToken          String?  @db.Text
  ghlPipelineId            String?
  ghlQualifiedStageId      String?
  ghlNewLeadStageId        String?
  ghlBookingUrl            String?
  businessName             String?
  niche                    String?
  offerName                String?
  offerPrice               Int?
  closeRate                Int?     @default(25)
  avgCallMinutes           Int?     @default(30)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  leads            Lead[]
  rules            ScoringRules?
  customQuestions  CustomQuestion[]
  resetTokens      PasswordResetToken[]
  accounts         Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Lead {
  id                 String     @id @default(cuid())
  userId             String
  name               String
  email              String
  phone              String?
  company            String?
  budget             String
  timeline           String
  problemDescription String     @db.Text
  aiScore            Int?
  aiReasoning        String?    @db.Text
  aiSummary          String?    @db.Text
  status             LeadStatus @default(PENDING)
  source             String?    @default("form")
  // ─── GoHighLevel sync state (null = no push attempted; behaves as before) ───
  ghlSyncStatus      String?    // "synced" | "failed" | "skipped"
  ghlContactId       String?
  ghlOpportunityId   String?
  ghlSyncError       String?    @db.Text
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([ghlSyncStatus])
}

model ScoringRules {
  id             String @id @default(cuid())
  userId         String @unique
  budgetWeight   Int    @default(30)
  timelineWeight Int    @default(25)
  urgencyWeight  Int    @default(25)
  qualityWeight  Int    @default(20)
  minScore       Int    @default(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model CustomQuestion {
  id       String @id @default(cuid())
  userId   String
  label    String
  type     String @default("text") // text, textarea, select
  options  String? @db.Text // JSON array for select options
  required Boolean @default(false)
  order    Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum LeadStatus {
  PENDING
  QUALIFIED
  DISQUALIFIED
}
